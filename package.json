{
  "name": "keyborg",
  "version": "2.14.1",
  "description": "Keyboard Navigation Detection for Web",
  "author": "Marat Abdullin <marata@microsoft.com>",
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "typings": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/microsoft/keyborg"
  },
  "scripts": {
    "build": "tsdown",
    "bundle-size": "yarn build && monosize measure",
    "format": "prettier --check .",
    "format:fix": "prettier --write .",
    "test": "playwright test",
    "test:serve": "storybook dev --port 3000 --no-open",
    "lint": "eslint src/ tests/",
    "lint:fix": "yarn lint --fix",
    "prepublishOnly": "yarn lint && yarn format && yarn build",
    "release": "release-it"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.58.2",
    "@storybook/react-vite": "^10.2.14",
    "@types/prop-types": "^15",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6",
    "eslint": "^10.3.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import-x": "^4.16.2",
    "monosize": "^0.9.0",
    "monosize-bundler-webpack": "^0.4.0",
    "monosize-storage-git": "^0.3.4",
    "playwright": "^1.58.2",
    "prettier": "^3.8.1",
    "prop-types": "^15",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-shadow": "^20.6.0",
    "release-it": "^20.0.0",
    "storybook": "^10.4.0",
    "tsdown": "^0.22",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.56.1",
    "vite": "^8.0.10"
  },
  "packageManager": "yarn@4.14.1"
}
