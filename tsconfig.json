{
  "compilerOptions": {
    "noEmit": true,
    "noResolve": false,
    "jsx": "preserve",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "target": "ES2019",
    "noImplicitAny": true,
    "noImplicitReturns": true,
    "noImplicitThis": true,
    "noUnusedLocals": true,
    "skipLibCheck": true,
    "strictNullChecks": true,
    "strictPropertyInitialization": true,
    "forceConsistentCasingInFileNames": true,
    "lib": ["DOM", "ESNext"]
  },
  "include": ["./src/**/*", "./tests/**/*", "./playwright.config.mts"],
  "exclude": ["dist", "node_modules"]
}
